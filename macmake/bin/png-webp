#!/usr/bin/env bash

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=img-options
source "$script_dir/img-options"

print_usage() {
	echo "Usage: $(basename "$0") [-w pixels] [-h pixels] [-Q] <source-png(s)>"
	img_print_size_options
}

if ! img_parse_options "$@"; then
	print_usage
	exit 1
fi

if [[ $IMG_SHOW_HELP -eq 1 ]]; then
	print_usage
	exit 0
fi

if [[ ${#IMG_SRC_FILES[@]} -eq 0 ]]; then
	print_usage
	exit 1
fi

missing=()
required_commands=(cwebp)
if img_has_resize; then
	required_commands+=(magick)
fi
for command_name in "${required_commands[@]}"; do
	if ! command -v "$command_name" >/dev/null 2>&1; then
		missing+=("$command_name")
	fi
done
if [[ ${#missing[@]} -gt 0 ]]; then
	echo "Missing required command(s): ${missing[*]}"
	exit 1
fi

img_init_tmp_dirs
trap img_cleanup_tmp_dirs EXIT

webp_quality=(-q 90)
if [[ $IMG_MAX_QUALITY -eq 1 ]]; then
	webp_quality=(-lossless)
fi

for src_png in "${IMG_SRC_FILES[@]}"; do
	if [[ ! -f "$src_png" ]]; then
		echo "Source PNG '$src_png' does not exist"
		continue
	fi

	if [[ "$src_png" != *.png ]]; then
		echo "Source file '$src_png' is not a .png"
		continue
	fi

	webp_file="${src_png%.png}$(img_size_suffix).webp"

	if [[ -e "$webp_file" ]]; then
		read -r -p "Replace existing '$webp_file'? [y/N] " replace
		case "$replace" in
			[yY]|[yY][eE][sS])
				;;
			*)
				echo "Skipped $src_png"
				continue
				;;
		esac
	fi

	if ! img_prepare_input "$src_png"; then
		echo "Failed to resize $src_png"
		continue
	fi

	if cwebp "${webp_quality[@]}" "$IMG_PREPARED_INPUT" -o "$webp_file"; then
		echo ""
		echo "Converted $src_png to:"
		echo "$webp_file"
	else
		echo "Failed to convert $src_png"
	fi
done
