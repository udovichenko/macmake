#!/usr/bin/env bash

if [[ $# -eq 0 ]]; then
	echo "Usage: $0 <source-png(s)>"
	exit 1
fi

if ! command -v cwebp >/dev/null 2>&1; then
	echo "cwebp not found"
	exit 1
fi

for src_png in "$@"; do
	if [[ ! -f "$src_png" ]]; then
		echo "Source PNG '$src_png' does not exist"
		continue
	fi

	if [[ "$src_png" != *.png ]]; then
		echo "Source file '$src_png' is not a .png"
		continue
	fi

	webp_file="${src_png%.png}.webp"

	if [[ -e "$webp_file" ]]; then
		read -r -p "Replace existing '$webp_file'? [y/N] " replace
		case "$replace" in
			[yY]|[yY][eE][sS])
				;;
			*)
				echo "Skipped $src_png"
				continue
				;;
		esac
	fi

	if cwebp -q 90 "$src_png" -o "$webp_file"; then
		echo ""
		echo "Converted $src_png to:"
		echo "$webp_file"
	else
		echo "Failed to convert $src_png"
	fi
done
