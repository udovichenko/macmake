#!/usr/bin/env bash

if [[ $# -eq 0 ]]; then
	echo "Usage: $0 <source-image(s)>"
	exit 1
fi

missing=()

for command_name in cwebp pngquant magick; do
	if ! command -v "$command_name" >/dev/null 2>&1; then
		missing+=("$command_name")
	fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
	echo "Missing required command(s): ${missing[*]}"
	echo "Install them and run this command again."
	exit 1
fi

tmp_dirs=()

cleanup() {
	for tmp_dir in "${tmp_dirs[@]}"; do
		if [[ -n "$tmp_dir" && -d "$tmp_dir" ]]; then
			rm -rf "$tmp_dir"
		fi
	done
}

trap cleanup EXIT

lowercase() {
	printf "%s" "$1" | tr "[:upper:]" "[:lower:]"
}

file_format() {
	case "$1" in
		png)
			echo "png"
			;;
		webp)
			echo "webp"
			;;
		jpg|jpeg|jpe)
			echo "jpeg"
			;;
		tif|tiff)
			echo "tiff"
			;;
		*)
			echo "$1"
			;;
	esac
}

prompt_replace() {
	local output_file="$1"
	local answer

	if [[ ! -e "$output_file" ]]; then
		return 0
	fi

	read -r -p "Replace existing '$output_file'? [y/N] " answer
	case "$answer" in
		[yY]|[yY][eE][sS])
			return 0
			;;
		*)
			echo "Skipped $output_file"
			return 1
			;;
	esac
}

for src_file in "$@"; do
	if [[ ! -f "$src_file" ]]; then
		echo "Source file '$src_file' does not exist"
		continue
	fi

	file_name="$(basename "$src_file")"
	dir_name="$(dirname "$src_file")"

	if [[ "$file_name" == *.* && "${file_name%.*}" != "" ]]; then
		base_name="${file_name%.*}"
		src_ext="$(lowercase "${file_name##*.}")"
	else
		base_name="$file_name"
		src_ext=""
	fi

	src_format="$(file_format "$src_ext")"
	jpg_ext="jpg"
	if [[ "$src_format" == "jpeg" && "$src_ext" == "jpeg" ]]; then
		jpg_ext="jpeg"
	fi

	webp_file="$dir_name/$base_name.webp"
	png_file="$dir_name/$base_name.png"
	jpg_file="$dir_name/$base_name.$jpg_ext"

	if [[ "$src_format" == "webp" ]]; then
		webp_file="$dir_name/$base_name-s.webp"
	fi

	if [[ "$src_format" == "png" ]]; then
		png_file="$dir_name/$base_name-s.png"
	fi

	if [[ "$src_format" == "jpeg" ]]; then
		jpg_file="$dir_name/$base_name-s.$jpg_ext"
	fi

	tmp_png_file=""

	make_tmp_png() {
		if [[ -n "$tmp_png_file" ]]; then
			return 0
		fi

		local tmp_dir
		tmp_dir="$(mktemp -d)"
		tmp_dirs+=("$tmp_dir")
		tmp_png_file="$tmp_dir/source.png"

		magick "${src_file}[0]" -auto-orient "$tmp_png_file"
	}

	echo ""
	echo "Converting $src_file"

	if prompt_replace "$webp_file"; then
		if [[ "$src_format" == "png" || "$src_format" == "jpeg" || "$src_format" == "tiff" || "$src_format" == "webp" ]]; then
			if cwebp -q 90 "$src_file" -o "$webp_file"; then
				echo "Created $webp_file"
			elif make_tmp_png && cwebp -q 90 "$tmp_png_file" -o "$webp_file"; then
				echo "Created $webp_file"
			else
				echo "Failed to create $webp_file"
			fi
		elif make_tmp_png && cwebp -q 90 "$tmp_png_file" -o "$webp_file"; then
			echo "Created $webp_file"
		else
			echo "Failed to create $webp_file"
		fi
	fi

	if prompt_replace "$png_file"; then
		if [[ "$src_format" == "png" ]]; then
			png_input="$src_file"
		elif make_tmp_png; then
			png_input="$tmp_png_file"
		else
			png_input=""
		fi

		if [[ -n "$png_input" ]] && pngquant --force --quality=65-80 "$png_input" --output "$png_file"; then
			echo "Created $png_file"
		else
			echo "Failed to create $png_file"
		fi
	fi

	if prompt_replace "$jpg_file"; then
		if magick "${src_file}[0]" -auto-orient -background white -alpha remove -alpha off -quality 90 "$jpg_file"; then
			echo "Created $jpg_file"
		else
			echo "Failed to create $jpg_file"
		fi
	fi
done
